---
import Layout from "../components/Layout.astro";
---

<Layout title="Jewellery">

<h1 class="text-2xl font-semibold mb-6 text-pink-400">Jewellery</h1>

<div class="mt-10 p-5 rounded-xl border border-white/10 bg-[#0d1117]">
  <p class="text-pink-400 text-sm mb-1">Instagram</p>
  <p class="text-gray-400 text-sm mb-3">
    Jewellery studies, materials, and fabrication work.
  </p>

  <a
    href="https://instagram.com/jumperkables_jewellery"
    target="_blank"
    class="text-cyan-400 hover:text-pink-400 transition"
  >
    instagram.com/jumperkables_jewellery ↗
  </a>
</div>

<p class="text-gray-400 mb-6">
  Handmade work exploring material, form, and precision.
</p>

<div class="grid grid-cols-2 gap-4">
  <img src="/images/j1.jpg" class="rounded-lg" />
  <img src="/images/j2.jpg" class="rounded-lg" />
</div>

<p class="text-sm text-gray-500 mt-6">
  More on 
</p>

</Layout>
