---
import Layout from "../components/Layout.astro";
---

<Layout title="Your Name">

<section class="py-20 space-y-20">

  <h1 class="text-4xl font-semibold mb-4">
    Your Name
  </h1>

  <p class="text-xl text-gray-300 mb-6">
    ML Engineer focused on performance, numerical stability, and efficient model training.
  </p>

  <p class="text-gray-400 max-w-2xl mb-12">
    Applied machine learning across physics-based modelling, medical imaging, and scientific datasets.
    Increasing focus on GPU performance, PyTorch internals, and system-level optimisation.
  </p>

  <p class="text-gray-400 max-w-2xl mb-12">
  <div class="h-px w-full bg-gradient-to-r from-cyan-500/20 via-transparent to-pink-500/20 my-12"></div>


  <!-- IMAGE -->
  <div class="w-40 h-40 md:w-48 md:h-48 shrink-0">
    <img
      src="/me.jpg"
      alt="Profile photo"
      class="w-full h-full object-cover rounded-xl border border-white/10"
    />
  </div>

  <!-- CAPABILITIES -->
  <div class="mb-14">
    <h2 class="text-lg font-semibold text-cyan-400 mb-4">Capabilities</h2>

    <div class="grid md:grid-cols-2 gap-3 text-gray-400">
      <div>PyTorch training systems & debugging</div>
      <div>Performance profiling & bottleneck analysis</div>
      <div>Training stability (mixed precision, NaNs)</div>
      <div>Applied ML in scientific domains</div>
      <div>Memory-efficient model design</div>
      <div>CUDA & low-level optimisation (active development)</div>
    </div>
  </div>

  <!-- FEATURED WORK -->
  <div class="mb-14">
    <h2 class="text-lg font-semibold text-cyan-400 mb-6">Selected Work</h2>

    <div class="space-y-8">

      <div class="card">
        <h3 class="font-medium mb-2">GPU-accelerated reconstruction</h3>
        <p class="text-gray-400">
          Iterative reconstruction pipeline focused on GPU efficiency, memory behaviour, and compute optimisation.
        </p>
      </div>

      <div class="card">
        <h3 class="font-medium mb-2">Skin cancer classification</h3>
        <p class="text-gray-400">
          Medical imaging system published in Nature Medicine. 
        </p>
      </div>

      <div class="card">
        <h3 class="font-medium mb-2">Archaeological CNN systems</h3>
        <p class="text-gray-400">
          Applied deep learning to scientific imaging. Published in Nature Scientific Reports
        </p>
      </div>

    </div>
  </div>

  <!-- NOTES -->
  <div class="mb-14">
    <h2 class="text-lg font-semibold text-cyan-400 mb-4">Notes</h2>
    <p class="text-gray-400">
      Writing on PyTorch performance, CUDA learning, and training stability.
    </p>
  </div>

  <!-- SOFT PERSONAL SIGNAL -->
  <p class="text-sm text-gray-500">
    Jewellery design and fabrication in spare time.
  </p>

</section>

</Layout>
