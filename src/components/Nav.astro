    <div style="
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    align-items: center;
    font-size: 14px;
    color: #9ca3af;
  ">

    <a href="/" class={`nav-link ${currentPath === "/" ? "active" : ""}`}>Home</a>

    <a href="/projects" class={`nav-link ${currentPath === "/projects" ? "active" : ""}`}>Projects</a>

    <a href="/publications" class={`nav-link ${currentPath === "/publications" ? "active" : ""}`}>Publications</a>

    <a href="/notes" class={`nav-link ${currentPath === "/notes" ? "active" : ""}`}>Notes</a>

    <a href="/jewellery" class={`nav-link jewellery ${currentPath === "/jewellery" ? "active" : ""}`}>Jewellery</a>

    <a href="https://github.com/Jumperkables" target="_blank" class="nav-link">
      GitHub ↗
    </a>

